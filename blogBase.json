uff08\u8868\u793a6\u6839\u68cd\u5b50\uff09\uff0c\u95ee\uff1a\u662f\u5426\u80fd\u642d\u51fa\u718a/\u8c61\n- \u56db\u6839\u68cd\u5b50\u4ee3\u8868\u52a8\u7269\u7684\u817f\uff0c\u8fd9\u4e9b\u68cd\u5b50\u5e94\u8be5\u6709\u76f8\u540c\u7684\u957f\u5ea6\u3002", "top": 0, "createdAt": 1775483050, "style": "", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script src='https://blog.meekdai.com/Gmeek/plugins/lightbox.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://cdn.luogu.com.cn/upload/usericon/1259913.png", "createdDate": "2026-04-06", "dateLabelColor": "#1f883d"}, "P5": {"htmlDir": "docs/post/zong-jie---di-si-jie-ke.html", "labels": ["\u603b\u7ed3"], "postTitle": "\u603b\u7ed3/\u7b2c\u56db\u8282\u8bfe", "postUrl": "post/zong-jie---di-si-jie-ke.html", "postSourceUrl": "https://github.com/AugestWM/AugestWM.github.io/issues/5", "commentNum": 0, "wordCount": 2290, "description": "# \u7b2c\u4e00\u9898\uff1a [\u4fbf\u5b9c\u7684\u8f66\u7968](https://www.luogu.com.cn/problem/T750168?contestId=320176)\n## \u9898\u76ee\u7b80\u8ff0\n\u4e00\u5171\u4e58\u5750$N$\u6b21\u5730\u94c1\uff0c\u5df2\u77e5\n- \u8d2d\u4e70\u7279\u6b8a\u7968 $b$ \u5143 $m$ \u6b21\n- \u8d2d\u4e70\u666e\u901a\u7968 $a$ \u5143 $1$  \u6b21\n\u95ee\uff1a\u600e\u4e48\u5750\u6700\u4f18\u60e0\n## \u9898\u76ee\u5206\u6790\n\u53ef\u4ee5\u5206\u4e3a\u4e24\u79cd\u60c5\u51b5\uff1a\n1. \u4e70\u666e\u901a\u7968\u4fbf\u5b9c \u5168\u4e70\u666e\u901a\u7968 `a * n`\n2. \u4e70\u7279\u6b8a\u7968\u4fbf\u5b9c \u5206\u4e3a\u4e24\u79cd\u60c5\u51b5\n    1. \u5168\u4e70\u7279\u6b8a\u7968\u4fbf\u5b9c `b * ceil(n * 1.0 / m)`\n    2. \u4e70\u5b8c\u7279\u6b8a\u7968\u4e70\u666e\u901a\u7968\u4fbf\u5b9c `n / m * b + (n - n / m * m)`\n\u6700\u540e\u7167\u5199\u5373\u53ef\n::::success[\u6b63\u786e\u4ee3\u7801]{close}\n```cpp\n#include <bits/stdc++.h>\nusing namespace std;\n\nint main()\n{\n\tint n, m, a, b;\n\tcin >> n >> m >> a >> b;\n\tif(m * a < b) //\u5982\u679c\u666e\u901a\u7968\u76f8\u5bf9\u4f18\u60e0\n\t{\n\t\tcout << a * n; //\u5168\u4e70\u666e\u901a\u7968\n\t\treturn 0;\n\t}\n\telse //\u5426\u5219\n\t{\n\t\tint s1 = ceil(n * 1.0 / m) * b; //1. \u5168\u4e70\u7279\u6b8a\u7968\n\t\tint s2 = n / m * b + (n - n / m * m); //2. \u4e70\u5b8c\u7279\u6b8a\u4e70\u666e\u901a\u7968\n\t\tcout << min(s1, s2); //\u53d6\u6700\u5c0f\u503c\n\t}\n\treturn 0;\n}\n```\n\n::::\n\n# \u7b2c\u4e8c\u9898\uff1a [\u597d\u6570](https://www.luogu.com.cn/problem/T708694?contestId=318983)\n## \u9898\u76ee\u7b80\u8ff0\n\u4e00\u4e2a\u6570\u5b57\u5305\u542b\u6240\u67090\uff5ek\u7684\u6570 \u5219\u79f0\u4ed6\u4e3a\u201c\u597d\u6570\u201d \u95ee\uff1a\u7ed9\u5b9a\u7684$N$\u4e2a\u6570\u4e2d\u6709\u591a\u5c11\u4e2a\u597d\u6570\n## \u9898\u76ee\u5206\u6790\n\u7528\u6570\u4f4d\u5206\u79bb + \u6876\u5373\u53ef\uff0c\u6876\u6807\u8bb0\u6709\u591a\u5c11\u662f\u5426\u662f\u597d\u6570\uff0c\u6570\u4f4d\u5206\u79bb\u7ed9\u6876\u6570\u636e\n\u6876\u8981`memset`!\n\u5927\u6982\u5c31\u662f\u8fd9\u6837\uff1a\n::::success[\u6b63\u786e\u4ee3\u7801]{close}\n```cpp\n#include<bits/stdc++.h>\nusing namespace std;\nconst int N = 10;\n\nbool a[N];\n\nint main() {\n\tint n, k;\n\tcin >> n >> k;\n\tint sum = 0;\n\n\tfor (int i = 1; i <= n; i ++) {\n\t\tmemset(a, 0, sizeof a);//\u521d\u59cb\u5316\n\t\tint x;\n\t\tcin >> x;\n\t\twhile(x)\n\t\t{\n\t\t\ta[x % 10] = 1;\n\t\t\tx /= 10;\n\t\t}//\u6570\u4f4d\u5206\u79bb\u8ba9\u6876\u6807\u8bb0\n\t\tint flag = 0;\n\t\tfor (int i = 0; i <= k; i ++) {\n\t\t\tif (a[i] == 0) {\n\t\t\t\tflag = 1;\n\t\t\t\tbreak;\n\t\t\t}\n\t\t}\n\t\tif (flag == 0) sum ++;//\u8ba1\u6570\n\t}\n\tcout << sum << endl;\n\treturn 0;\n}\n\n```\n::::\n\n# \u7b2c\u4e09\u9898\uff1a [\u77f3\u5934\u5760\u843d](https://www.luogu.com.cn/problem/T750172?contestId=320176)\n## \u9898\u76ee\u7b80\u8ff0\n\u544a\u8bc9\u4f60\u4e00\u4e2a\u56fe\uff0c\u5df2\u77e5\u77f3\u5934\u662f`*`\uff0c\u969c\u788d\u7269\u662f`o`\uff0c\u5176\u4f59\u90fd\u662f\u7a7a\uff0c\u95ee\u5728\u77f3\u5934\u90fd\u5760\u843d\u4e4b\u540e\u7684\u56fe\u662f\u957f\u4ec0\u4e48\u6837\u7684\n\n## \u9898\u76ee\u5206\u6790\n\u5df2\u77e5\u9ad8\u6700\u591a50,\u8bf4\u660e\u53ef\u4ee5\u5bf9\u4e8e\u6bcf\u4e00\u4e2a\u77f3\u5934\u505a50\u6b21\u5904\u7406\n\u4e5f\u5c31\u662f\u5f53\u67d0\u4e00\u4e2a\u77f3\u5934\u4e0b\u9762\u662f\u7a7a\u5355\u5143\u683c\u7684\u65f6\u5019\uff0c\u8bf4\u660e\u4ed6\u53ef\u4ee5\u4ea4\u6362\u4ed6\u4eec\u4e24\u4e2a\u7684\u4f4d\u7f6e\uff0c\u7136\u540e\u5faa\u73af50\u6b21\uff08\u56e0\u4e3a\u9ad8\u6700\u592750\uff09\uff0c\u6700\u540e\u8f93\u51fa\u6700\u540e\u7684\u56fe\n\u8bb0\u5f97`memset`!\n::::success[\u6b63\u786e\u4ee3\u7801]{close}\n```cpp\n#include<bits/stdc++.h>\nusing namespace std;\n\nchar a[60][60];\n\nint main() {\n\tint t;\n\tcin >> t;\n\twhile (t --) {\n\t\tmemset(a, 0, sizeof a);\n\t\tint n, m;\n\t\tcin >> n >> m;\n\t\tfor (int i = 1; i <= n; i ++) {\n\t\t\tfor (int j = 1; j <= m; j ++) {\n\t\t\t\tcin >> a[j][i];\n\t\t\t}\n\t\t}\n\t\tfor (int x = 1; x <= 60; x ++) {//\u5faa\u73af50\u6b21\uff0c\u4fdd\u966960\u6b21\n\t\t\tfor (int i = 1; i <= n; i ++) {\n\t\t\t\tfor (int j = 1; j <= m; j ++) {\n\t\t\t\t\tif (a[j][i] == '*' and a[j][i + 1] == '.') {\n\t\t\t\t\t\ta[j][i] = '.';\n\t\t\t\t\t\ta[j][i + 1] = '*';\n\t\t\t\t\t\t//\u67d0\u4e00\u4e2a\u77f3\u5934\u4e0b\u9762\u662f\u7a7a\u683c\uff0c\u90a3\u4e48\u5c31\u4ea4\u6362\u4ed6\u4eec\u7684\u4f4d\u7f6e\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\t\n\t\t}\n\t\tfor (int i = 1; i <= n; i ++) {\n\t\t\tfor (int j = 1; j <= m; j ++) {\n\t\t\t\tcout << a[j][i];\n\t\t\t}\n\t\t\tcout << endl;\n\t\t}\n\t}\n\treturn 0;\n}\n\n```\n::::\u3002", "top": 0, "createdAt": 1776520509, "style": "", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script src='https://blog.meekdai.com/Gmeek/plugins/lightbox.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script